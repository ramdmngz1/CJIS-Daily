<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No data is collected, sent, or shared outside the device. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- App does not track users across apps or websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains used. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!--
        Required-reason API declarations.
        UserDefaults is used to persist app settings (theme, notification time, quiz
        progress, and daily completion state) that are only accessible to this app.
        Reason CA92.1: Access info from the same app, per user, to provide app features.
    -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
